# ============================================================
# Credit Risk XAI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Application ───────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_VERSION=1.0.0
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=your-secret-key-here-change-this

# ── Model Paths ───────────────────────────────────────────
MODEL_PATH=models/trained/best_model.pkl
PREPROCESSOR_PATH=models/trained/preprocessor.pkl
FEATURE_NAMES_PATH=models/trained/feature_names.pkl
MODEL_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///data/credit_risk.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://xai:password@localhost:5432/credit_risk
POSTGRES_DB=credit_risk
POSTGRES_USER=xai
POSTGRES_PASSWORD=xai_password_change_in_production

# ── MLflow ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db
MLFLOW_EXPERIMENT_NAME=credit_risk_xai_v1
# For remote MLflow server:
# MLFLOW_TRACKING_URI=http://mlflow-server:5000
# MLFLOW_TRACKING_USERNAME=your-username
# MLFLOW_TRACKING_PASSWORD=your-password

# ── AWS (for DVC remote + S3 model storage) ───────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your-credit-risk-xai-bucket
DVC_REMOTE_URL=s3://your-bucket/dvc-store

# ── GCP (alternative cloud storage) ──────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET_NAME=your-gcs-bucket

# ── Azure (alternative) ───────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_CONTAINER_NAME=credit-risk-models

# ── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=your-api-key-change-this
RATE_LIMIT_PER_MINUTE=100

# ── Streamlit ─────────────────────────────────────────────
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ── Monitoring & Alerts ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/your-webhook
ALERT_EMAIL=risk-alerts@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# PSI Thresholds
PSI_WARNING_THRESHOLD=0.10
PSI_DRIFT_THRESHOLD=0.20

# ── Fairness ──────────────────────────────────────────────
FAIRNESS_DPD_THRESHOLD=0.10
FAIRNESS_DIR_THRESHOLD=0.80
FAIRNESS_EOD_THRESHOLD=0.10
