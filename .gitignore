# ============================================================
# .gitignore — Credit Risk XAI Platform
# ============================================================

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.hypothesis/
.ruff_cache/

# ── Virtual Environments ──────────────────────────────────
venv/
.venv/
env/
ENV/
.env
!.env.example

# ── Data (DVC tracked) ───────────────────────────────────
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.parquet
data/processed/
data/interim/
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Models (DVC tracked) ──────────────────────────────────
models/trained/*.pkl
models/trained/*.json
models/calibrated/*.pkl
models/registry/
!models/trained/.gitkeep
!models/calibrated/.gitkeep

# ── MLflow ────────────────────────────────────────────────
mlruns/
mlflow.db

# ── Generated Reports ─────────────────────────────────────
reports/generated/*.pdf
reports/generated/*.xlsx
reports/generated/shap/*.png
reports/generated/lime/*.png
reports/generated/fairness/*.png
reports/generated/monitoring/*.html
reports/generated/monitoring/*.json
!reports/generated/.gitkeep

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb_checkpoints/

# ── IDE / Editors ─────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────
.docker/

# ── Secrets ───────────────────────────────────────────────
.env
secrets/
*.pem
*.key

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── DVC ──────────────────────────────────────────────────
/tmp
.dvc/tmp
.dvc/cache
